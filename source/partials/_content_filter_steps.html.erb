<%
  # Generic renderer for a content-filtered step list.
  #
  # Locals (all required):
  #   category_structure — Hash of { 'LABEL' => ['step-name', ...] }
  #   category_order     — Comma-separated string of button order, e.g. 'DEV,STE,SIT'
  #   partials_directory — Partial path prefix, e.g. 'aks/partials/crime-switchover'
  #
  # Optional:
  #   filter_label     — Overrides the default 'Make a selection:' prompt
  #   no_selection_msg — Overrides the default placeholder message
  #
  # The superset order and data-filter-values are computed automatically.
  # Authors should never need to edit this file.

  superset = []
  category_structure.each_value { |steps| steps.each { |s| superset << s unless superset.include?(s) } }
  step_categories = superset.map { |step| [step, category_structure.select { |_, v| v.include?(step) }.keys] }

  _filter_label     = defined?(filter_label)     && filter_label     ? filter_label     : nil
  _no_selection_msg = defined?(no_selection_msg) && no_selection_msg ? no_selection_msg : 'Please make a selection above.'
%>
<div data-content-filter<% if category_order %> data-filter-order="<%= category_order %>"<% end %><% if _filter_label %> data-filter-label="<%= _filter_label %>"<% end %>></div>

<div class="content-filter-container">
<div class="content-filter-no-selection">
<p><%= _no_selection_msg %></p>
</div>
<% step_categories.each do |step, categories| %>
<div data-filter-values="<%= categories.join(' ') %>">
<div class="step-section">
<%= partial "#{partials_directory}/step-#{step}" %>
</div>
</div>
<% end %>
</div>
